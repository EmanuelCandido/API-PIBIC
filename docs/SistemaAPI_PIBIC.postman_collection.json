{
  "info": {
    "name": "SistemaAPI PIBIC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{password}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "username",
      "value": "admin"
    },
    {
      "key": "password",
      "value": "admin123"
    }
  ],
  "item": [
    {
      "name": "OpenAPI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/openapi.yaml"
      }
    },
    {
      "name": "Criar professor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Dra. Silva\",\n  \"email\": \"silva@email.com\",\n  \"materia\": \"Clinica Medica\"\n}"
        },
        "url": "{{baseUrl}}/professores"
      }
    },
    {
      "name": "Criar aluno",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Ana\",\n  \"email\": \"ana@email.com\",\n  \"curso\": \"Medicina\",\n  \"periodo\": \"4\"\n}"
        },
        "url": "{{baseUrl}}/alunos"
      }
    },
    {
      "name": "Criar caso clinico",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idProfessor\": 1,\n  \"titulo\": \"Caso respiratorio\",\n  \"dificuldade\": \"MEDIA\",\n  \"disciplina\": \"Clinica Medica\",\n  \"areaSaude\": \"Medicina\",\n  \"estilo\": \"Multipla escolha\",\n  \"especialidade\": \"Pneumologia\",\n  \"objetivoAprendizagem\": \"Avaliar conduta inicial\",\n  \"nivelDificuldade\": \"MEDIA\"\n}"
        },
        "url": "{{baseUrl}}/casos"
      }
    },
    {
      "name": "Criar pergunta",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"texto\": \"Qual a melhor conduta inicial?\",\n  \"tipo\": \"MULTIPLA_ESCOLHA\",\n  \"gabarito\": \"A\",\n  \"resposta\": \"A\",\n  \"tempoEsperado\": \"5 minutos\",\n  \"alternativas\": [\n    { \"letra\": \"A\", \"texto\": \"Conduta correta\", \"correta\": true },\n    { \"letra\": \"B\", \"texto\": \"Conduta inadequada\", \"correta\": false }\n  ]\n}"
        },
        "url": "{{baseUrl}}/casos/1/perguntas"
      }
    },
    {
      "name": "Publicar caso",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/casos/1/publicar"
      }
    },
    {
      "name": "Casos disponiveis do aluno",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/alunos/1/casos-disponiveis"
      }
    },
    {
      "name": "Responder caso",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"respostas\": [\n    {\n      \"idPergunta\": 1,\n      \"respostaMarcada\": \"A\"\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/alunos/1/casos/1/responder"
      }
    },
    {
      "name": "Desempenho do aluno",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/alunos/1/desempenho"
      }
    }
  ]
}
